{
  "name": "trollcity",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.x <25.0"
  },
  "scripts": {
    "dev": "node ./scripts/generate-version.js && vite",
    "build": "node ./scripts/generate-version.js && vite build",
    "build:web": "npm run build",
    "lint": "eslint .",
    "run:migrations": "node ./scripts/run_migrations.js",
    "check:sounds": "node ./scripts/check_sounds.js",
    "preview": "set NODE_PATH=./node_modules&& node ./node_modules/vite/bin/vite.js preview",
    "check": "tsc --noEmit",
    "test": "jest",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui",
    "seed:test-users": "tsx ./scripts/seed_test_users.ts",
    "cleanup:test-users": "tsx ./scripts/cleanup_test_users.ts",
    "cap:init": "cap init trollcity com.trollcity.app --web-dir=dist",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run build && cap sync",
    "cap:sync:android": "npm run build && cap sync android",
    "cap:open:android": "cap open android",
    "cap:run:android": "npm run cap:sync:android && cap run android",
    "android:dev": "npm run cap:sync:android && cap run android --livereload --external",
    "deploy:edge": "supabase functions deploy --no-verify-jwt"
  },
